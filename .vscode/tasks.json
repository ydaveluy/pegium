{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Build Arithmetics LSP Server",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "pegium-example-arithmetics-lsp",
                "-j"
            ],
            "dependsOn": [
                "CMake Configure"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Compile Arithmetics VSCode Extension",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "if [ ! -d node_modules ]; then npm install; fi"
            ],
            "options": {
                "cwd": "${workspaceFolder}/examples/arithmetics"
            },
            "problemMatcher": []
        },
        {
            "label": "Build Arithmetics VSCode Extension",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "compile"
            ],
            "dependsOn": [
                "Compile Arithmetics VSCode Extension"
            ],
            "options": {
                "cwd": "${workspaceFolder}/examples/arithmetics"
            },
            "problemMatcher": "$tsc"
        },
        {
            "label": "Prepare Arithmetics Extension",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Arithmetics LSP Server",
                "Build Arithmetics VSCode Extension"
            ],
            "problemMatcher": []
