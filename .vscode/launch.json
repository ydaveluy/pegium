{
    "configurations": [
        {
            "name": "Run Arithmetics Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--new-window",
                "--extensionDevelopmentPath=${workspaceFolder}/examples/arithmetics",
                "${workspaceFolder}/examples/arithmetics/example"
            ],
            "outFiles": [
                "${workspaceFolder}/examples/arithmetics/vscode/out/**/*.js"
            ],
            "preLaunchTask": "Prepare Arithmetics Extension"
        },
        {
            "name": "Run DomainModel Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--new-window",
                "--extensionDevelopmentPath=${workspaceFolder}/examples/domainmodel",
                "${workspaceFolder}/examples/domainmodel/example"
            ],
            "outFiles": [
                "${workspaceFolder}/examples/domainmodel/vscode/out/**/*.js"
            ],
            "preLaunchTask": "Prepare DomainModel Extension"
        },
        {
            "name": "Run Requirements Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--new-window",
                "--extensionDevelopmentPath=${workspaceFolder}/examples/requirements",
                "${workspaceFolder}/examples/requirements/example"
            ],
            "outFiles": [
                "${workspaceFolder}/examples/requirements/vscode/out/**/*.js"
            ],
            "preLaunchTask": "Prepare Requirements Extension"
        },
        {
            "name": "Run Statemachine Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--new-window",
                "--extensionDevelopmentPath=${workspaceFolder}/examples/statemachine",
                "${workspaceFolder}/examples/statemachine/example"
            ],
            "outFiles": [
                "${workspaceFolder}/examples/statemachine/vscode/out/**/*.js"
            ],
            "preLaunchTask": "Prepare Statemachine Extension"
        },
        {
            "name": "Debug PegiumCoreUnitTest",
            "type": "cppdbg",
            "cwd": "${workspaceFolder}",
            "request": "launch",
            "program": "${workspaceFolder}/build/PegiumCoreUnitTest",
            "args": []
        },
        {
            "name": "Debug PegiumLspUnitTest",
            "type": "cppdbg",
            "cwd": "${workspaceFolder}",
            "request": "launch",
            "program": "${workspaceFolder}/build/PegiumLspUnitTest",
            "args": []
        },
        {
            "name": "Debug PegiumIntegrationTest",
            "type": "cppdbg",
            "cwd": "${workspaceFolder}",
            "request": "launch",
            "program": "${workspaceFolder}/build/PegiumIntegrationTest",
            "args": []
        }
    ],
    "version": "2.0.0"
}
