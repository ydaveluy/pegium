{
  "name": "pegium-requirements-dsl",
  "displayName": "Pegium Requirements DSL",
  "version": "0.1.0",
  "description": "Requirements + tests example language powered by Pegium",
  "license": "MIT",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:requirements-lang",
    "onLanguage:tests-lang"
  ],
  "main": "./vscode/out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "requirements-lang",
        "aliases": [
          "Requirements Language",
          "requirements-lang"
        ],
        "extensions": [
          ".req"
        ],
        "configuration": "./vscode/language-configuration.json"
      },
      {
        "id": "tests-lang",
        "aliases": [
          "Tests Language",
          "tests-lang"
        ],
        "extensions": [
          ".tst"
        ],
        "configuration": "./vscode/language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "requirements-lang",
        "scopeName": "source.requirements-lang",
        "path": "./vscode/syntaxes/requirements.tmLanguage.json"
      },
      {
        "language": "tests-lang",
        "scopeName": "source.tests-lang",
        "path": "./vscode/syntaxes/tests.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Pegium Requirements",
      "properties": {
        "pegium.requirements.serverPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the pegium-example-requirements-lsp executable. If empty, common build locations are probed."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./vscode/tsconfig.json",
    "test": "npm run compile && node ./vscode/out/test/runTest.js",
    "watch": "tsc -p ./vscode/tsconfig.json -w",
    "vscode:prepublish": "npm run compile"
  },
  "files": [
    "package.json",
    "README.md",
    "example",
    "vscode/out",
    "vscode/src",
    "vscode/language-configuration.json",
    "vscode/syntaxes"
  ],
  "dependencies": {
    "vscode-languageclient": "~9.0.1"
  },
  "devDependencies": {
    "@vscode/test-electron": "^2.4.1",
    "@types/node": "^20.17.17",
    "@types/vscode": "^1.86.0",
    "typescript": "^5.7.2"
  }
}
