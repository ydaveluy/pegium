{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Requirements Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/vscode",
                "${workspaceFolder}/example"
            ],
            "outFiles": [
                "${workspaceFolder}/vscode/out/**/*.js"
            ],
            "preLaunchTask": "npm: compile - vscode"
        }
    ]
}
