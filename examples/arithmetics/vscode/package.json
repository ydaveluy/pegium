{
  "name": "pegium-arithmetics-dsl",
  "publisher": "pegium",
  "displayName": "Pegium Arithmetics DSL",
  "version": "0.1.0",
  "description": "Arithmetics example language powered by Pegium",
  "license": "MIT",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:arithmetics"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "arithmetics",
        "aliases": [
          "Arithmetics",
          "arithmetics"
        ],
        "extensions": [
          ".calc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "arithmetics",
        "scopeName": "source.arithmetics",
        "path": "./syntaxes/arithmetics.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Pegium Arithmetics",
      "properties": {
        "pegium.arithmetics.serverPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the pegium-example-arithmetics-lsp executable. If empty, common build locations are probed."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "bundle": "node esbuild.mjs --production",
    "watch": "tsc -p ./tsconfig.json -w",
    "test": "npm run compile && node ./out/test/runTest.js",
    "vscode:prepublish": "npm run bundle",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "files": [
    "package.json",
    "out",
    "language-configuration.json",
    "syntaxes"
  ],
  "dependencies": {
    "vscode-languageclient": "~9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.17",
    "@types/vscode": "^1.86.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2"
  },
  "vsce": {
    "dependencies": false
  }
}
